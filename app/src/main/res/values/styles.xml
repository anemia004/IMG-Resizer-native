<resources>
    <style name="WinButton">
        <!-- Same background as HTML (#C0C0C0 with raised border) -->
        <item name="android:background">@drawable/btn_selector</item>
        <item name="android:textColor">#000000</item>
        <!-- Use a clean sans-serif that resembles Segoe UI -->
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <!-- Match HTML padding: 5px 18px -->
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
        <!-- Minimum width from HTML -->
        <item name="android:minWidth">80dp</item>
        <!-- Prevent the system from overriding the minimum height -->
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="WinEditText">
        <item name="android:background">@drawable/bg_inset</item>
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">13sp</item>
        <item name="android:padding">6dp</item>
    </style>

    <style name="WinTextView">
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
