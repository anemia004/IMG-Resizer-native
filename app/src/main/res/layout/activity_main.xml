<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008080"
    android:padding="16dp">

    <!-- The window frame -->
    <LinearLayout
        android:id="@+id/window"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_window"
        android:padding="2dp">

        <!-- Title bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/title_bar_gradient"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📷 IMG Resizer"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />

            <!-- Window controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_minimize"
                    style="@style/WinButton"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="—"
                    android:textSize="10sp"
                    android:padding="0dp"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btn_maximize"
                    style="@style/WinButton"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="□"
                    android:textSize="10sp"
                    android:padding="0dp"
                    android:gravity="center"
                    android:layout_marginLeft="2dp" />

                <Button
                    android:id="@+id/btn_close"
                    style="@style/WinButton"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="✕"
                    android:textSize="10sp"
                    android:padding="0dp"
                    android:gravity="center"
                    android:layout_marginLeft="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Window body (will be toggled by minimize) -->
        <ScrollView
            android:id="@+id/window_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Open Image row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        style="@style/WinTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open Image:" />

                    <Button
                        android:id="@+id/btnPickImage"
                        style="@style/WinButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Browse…" />

                    <TextView
                        style="@style/WinTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(stays on device)"
                        android:textSize="10sp"
                        android:textColor="#222222" />
                </LinearLayout>

                <!-- Original info -->
                <TextView
                    android:id="@+id/tvOriginalInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_inset"
                    android:padding="6dp"
                    android:text="No image loaded."
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp" />

                <!-- Preview area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:id="@+id/imgOriginal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="150dp"
                        android:scaleType="fitCenter"
                        android:background="@drawable/bg_inset"
                        android:contentDescription="Original" />

                    <ImageView
                        android:id="@+id/imgProcessed"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="150dp"
                        android:scaleType="fitCenter"
                        android:background="@drawable/bg_inset"
                        android:contentDescription="Processed"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>

                <!-- Mode selection -->
                <RadioGroup
                    android:id="@+id/rgMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:checkedButton="@id/rbDimensions"
                    android:paddingBottom="8dp">

                    <RadioButton
                        android:id="@+id/rbDimensions"
                        style="@style/WinTextView"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Resize by Dimensions"
                        android:textColor="#000000" />

                    <RadioButton
                        android:id="@+id/rbFileSize"
                        style="@style/WinTextView"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Resize by File Size (KB)"
                        android:textColor="#000000" />
                </RadioGroup>

                <!-- Dimensions controls -->
                <LinearLayout
                    android:id="@+id/layoutDimensions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="4dp">

                        <TextView
                            style="@style/WinTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Width:" />

                        <EditText
                            android:id="@+id/etWidth"
                            style="@style/WinEditText"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="800"
                            android:layout_marginLeft="4dp" />

                        <TextView
                            style="@style/WinTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Height:"
                            android:layout_marginLeft="8dp" />

                        <EditText
                            android:id="@+id/etHeight"
                            style="@style/WinEditText"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="600"
                            android:layout_marginLeft="4dp" />
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cbAspectRatio"
                        style="@style/WinTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep aspect ratio"
                        android:checked="true"
                        android:textColor="#000000"
                        android:paddingBottom="4dp" />

                    <Button
                        android:id="@+id/btnResize"
                        style="@style/WinButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Resize" />
                </LinearLayout>

                <!-- File size controls -->
                <LinearLayout
                    android:id="@+id/layoutFileSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="8dp">

                    <TextView
                        style="@style/WinTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target KB:" />

                    <EditText
                        android:id="@+id/etTargetKB"
                        style="@style/WinEditText"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="100"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnCompress"
                        style="@style/WinButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Compress" />
                </LinearLayout>

                <!-- Horizontal rule -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#808080"
                    android:layout_marginVertical="8dp" />

                <!-- Format & quality -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        style="@style/WinTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Format:" />

                    <Spinner
                        android:id="@+id/spFormat"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_inset"
                        android:entries="@array/formats"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutQuality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        style="@style/WinTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quality:" />

                    <SeekBar
                        android:id="@+id/sbQuality"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="92"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnDownload"
                    style="@style/WinButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💾 Download"
                    android:enabled="false" />

                <!-- Status bar -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_inset"
                    android:padding="6dp"
                    android:text="Ready."
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</RelativeLayout>
